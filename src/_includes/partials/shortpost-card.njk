{# --------------------------------
   Webmentions (same pattern as posts)
--------------------------------- #}

{% set pageUrl = 'https://inside-the-dugout.de' + post.page.url %}
{% set mentionsByTarget = webmention.children | groupBy("wm-target") %}
{% set pageMentions = mentionsByTarget[pageUrl] %}

{% set likes = 0 %}
{% set reposts = 0 %}
{% set replies = 0 %}

{% if pageMentions %}
  {% for wm in pageMentions %}
    {% if wm["wm-property"] == "like-of" %}
      {% set likes = likes + 1 %}
    {% elif wm["wm-property"] == "repost-of" %}
      {% set reposts = reposts + 1 %}
    {% elif wm["wm-property"] == "in-reply-to" or wm["in-reply-to"] %}
      {% set replies = replies + 1 %}
    {% endif %}
  {% endfor %}
{% endif %}

{# -------------------------------
   Shortpost card layout
-------------------------------- #}

<div class="{% if isIndex %}w-full self-stretch{% else %}max-w-2xl mx-auto w-full{% endif %} p-2 mb-2">
  <div
    class="relative rounded-sm shadow-md bg-[#F9F9F9] border border-slate-200
           transition-all duration-200 hover:border-[#1D2D50]
           flex flex-col {% if isIndex %}min-h-[480px] max-h-[480px] overflow-hidden{% else %}h-full{% endif %}">

    <!-- left accent bar -->
    <div
      class="absolute left-0 top-0 h-full w-1 bg-[#1D2D50]
             opacity-70 transition-all duration-200
             hover:bg-[#C8102E]">
    </div>

    <!-- content -->
    <div class="pl-7 pr-6 py-4 flex-1 {% if isIndex %}overflow-hidden{% endif %} relative">
      <p class="mb-3 text-xs font-medium tracking-wide uppercase"
         style="color:#1D2D50"
         title="Published date"
         datetime="{{ post.date.toISOString() }}">
        {{ post.date.toISOString().slice(0,16).replace("T"," ") }}
      </p>

      <div class="prose max-w-none text-sm text-slate-800">
        {{ post.templateContent | safe }}
      </div>

      <!-- fade-out gradient, index only -->
      {% if isIndex %}
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#F9F9F9] to-transparent pointer-events-none"></div>
      {% endif %}
    </div>

    <!-- footer -->
    <div
      class="px-6 py-3 border-t flex items-center justify-between text-xs flex-shrink-0"
      style="background-color:#F9F9F9; border-color:#E2E8F0;"
    >

      <!-- LEFT: reactions -->
      <div class="flex items-center gap-4 text-slate-600">

        {% if likes > 0 %}
          <span class="flex items-center gap-1" title="Likes">
            ❤️ Likes: {{ likes }}
          </span>
        {% endif %}

        {% if reposts > 0 %}
          <span class="flex items-center gap-1" title="Reposts">
            🔁 Shares: {{ reposts }}
          </span>
        {% endif %}

        {% if replies > 0 %}
          <span class="flex items-center gap-1" title="Replies">
            💬 Kommentare: {{ replies }}
          </span>
        {% endif %}

      </div>

      <!-- RIGHT: permalink -->
      <a href="{{ post.url | url }}"
        class="font-semibold hover:underline"
        style="color:#C8102E">
        Permalink →
      </a>

    </div>

  </div>
</div>