---
layout: default
title: Archiv
permalink: /archiv/
---

<h1 class="text-3xl font-bold mb-10">Artikelarchiv</h1>

{% set groupedPosts = collections.posts | groupPostsByYear %}

<div class="space-y-12">

  {% for group in groupedPosts %}

    <section>

      <h2 class="text-2xl font-bold mb-4 border-b border-slate-300 pb-2">
        {{ group.year }}
      </h2>

      <div class="space-y-2">

        {% for post in group.posts %}

          <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">

            <span class="w-34 shrink-0 text-sm text-slate-500">
              {{ post.date | readableDate }}
            </span>
            <a
              href="{{ post.url }}"
              class="text-slate-800 hover:text-blue-700 underline"
            >
              {{ post.data.title }}
            </a>

          </div>

        {% endfor %}

      </div>

    </section>

  {% endfor %}

</div>