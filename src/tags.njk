---
layout: default
title: Schlagwörter
permalink: "tags/index.html"
---

<h1 class="text-3xl leading-normal font-bold mt-0 mb-7 text-center">{{ title }}</h1>

<h2 class="text-xl font-semibold mb-4 text-center text-slate-700">Formate</h2>
<div class="flex justify-center flex-wrap mb-12">
    {% for slug, length in collections.formatList %}
    <a href="{{ '/tags/' | url }}{{ slug }}" class="inline-block mx-1 mb-3 px-4 py-2 bg-red-50 text-red-800 font-medium rounded-full border border-red-200">
        {{ formats[slug] }}
        <span class="px-2 py-1 ml-1 text-xs font-semibold bg-red-200 text-red-900 rounded-full">{{ length }}</span>
    </a>
    {% endfor %}
</div>

<h2 class="text-xl font-semibold mb-4 text-center text-slate-700">Themen</h2>
<div class="flex justify-center flex-wrap pb-24">
    {% for name, length in collections.tagList %}
    <a href="{{ '/tags/' | url }}{{ name }}" class="inline-block mx-1 mb-3 px-4 py-2 bg-slate-200 text-slate-700 font-medium rounded-full">
        {{ name | capitalize }}
        <span class="px-2 py-1 ml-1 text-xs font-semibold bg-teal-300 text-teal-800 rounded-full">{{ length }}</span>
    </a>
    {% endfor %}
</div>

<h1 class="text-3xl font-bold mb-10 text-center">Artikelarchiv</h1>
{% set groupedPosts = collections.posts | groupPostsByYear %}
<div class="space-y-12 max-w-2xl mx-auto">

  {% for group in groupedPosts %}

    <section>

      <h2 class="text-2xl font-bold mb-4 border-b border-slate-300 pb-2">
        {{ group.year }}
      </h2>

      <div class="space-y-2">

        {% for post in group.posts %}

          <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">

            <span class="w-34 shrink-0 text-sm text-slate-500">
              {{ post.date | readableDate }}
            </span>
            <a href="{{ post.url }}" class="text-slate-800 hover:text-blue-700 underline"> {{ post.data.title }} </a>

          </div>

        {% endfor %}

      </div>

    </section>

  {% endfor %}

</div>